#include <stdint.h>

#define RCC_AHB2ENR    (*((volatile uint32_t*)0x4002104C))
#define RCC_APB1ENR1   (*((volatile uint32_t*)0x40021058))

#define GPIOA_MODER    (*((volatile uint32_t*)0x48000000))
#define GPIOA_AFRL     (*((volatile uint32_t*)0x48000020))

#define USART2_CR1     (*((volatile uint32_t*)0x40004400))
#define USART2_BRR     (*((volatile uint32_t*)0x4000440C))  // Correct on STM32L4
#define USART2_ISR     (*((volatile uint32_t*)0x4000441C))
#define USART2_TDR     (*((volatile uint32_t*)0x40004428))

static void delay(volatile uint32_t count)
{
    while (count--) { }
}

static void uart2_init(void)
{
    RCC_AHB2ENR  |= (1U << 0);   // Enable GPIOA clock
    RCC_APB1ENR1 |= (1U << 17);  // Enable USART2 clock

    GPIOA_MODER &= ~(3U << (2U * 2U));
    GPIOA_MODER |=  (2U << (2U * 2U));   // PA2 = alternate function mode

    GPIOA_AFRL  &= ~(0xFU << (4U * 2U));
    GPIOA_AFRL  |=  (7U   << (4U * 2U)); // PA2 = AF7 = USART2_TX

    USART2_BRR = 416U;                   // 4 MHz / 9600 baud
    USART2_CR1 |= (1U << 3);             // TE: transmitter enable
    USART2_CR1 |= (1U << 0);             // UE: USART enable
}

static void uart2_send_char(char c)
{
    while ((USART2_ISR & (1U << 7)) == 0U) { }  // Wait until TX register empty
    USART2_TDR = (uint8_t)c;
}

static void uart2_send_string(const char *s)
{
    while (*s != '\0')
    {
        uart2_send_char(*s);
        s++;
    }
}

