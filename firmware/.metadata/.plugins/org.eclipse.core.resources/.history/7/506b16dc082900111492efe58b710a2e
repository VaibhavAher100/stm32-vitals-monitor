#include <stdint.h>

#define RCC_AHB2ENR    (*((volatile uint32_t*)0x4002104C))
#define RCC_APB1ENR1   (*((volatile uint32_t*)0x40021058))
#define GPIOA_MODER    (*((volatile uint32_t*)0x48000000))
#define GPIOA_AFRL     (*((volatile uint32_t*)0x48000020))
#define GPIOA_ODR      (*((volatile uint32_t*)0x48000014))
#define USART2_BRR     (*((volatile uint32_t*)0x40004408))
#define USART2_CR1     (*((volatile uint32_t*)0x40004400))
#define USART2_ISR     (*((volatile uint32_t*)0x4000441C))
#define USART2_TDR     (*((volatile uint32_t*)0x40004428))

void delay(volatile uint32_t count)
{
    while(count--);
}

int main(void)
{
    /* Enable GPIOA and USART2 clocks */
    RCC_AHB2ENR  |= (1U << 0);
    RCC_APB1ENR1 |= (1U << 17);

    /* Small delay after clock enable */
    delay(100);

    /* PA5 as output for LED */
    GPIOA_MODER &= ~(3U << 10);
    GPIOA_MODER |=  (1U << 10);

    /* PA2 as Alternate Function mode */
    GPIOA_MODER &= ~(3U << 4);
    GPIOA_MODER |=  (2U << 4);

    /* PA2 AF7 = USART2_TX */
    GPIOA_AFRL &= ~(0xFU << 8);
    GPIOA_AFRL |=  (7U   << 8);

    /* BRR for 9600 baud at 4MHz */
    USART2_BRR = 1667;

    USART2_CR1 = (1U << 3) | (1U << 0);
    /* Long 2-second delay before first transmission */
    delay(2000000);

    /* Blink 5 times fast to signal UART is about to send */
    for(int i = 0; i < 5; i++)
    {
        GPIOA_ODR |=  (1U << 5);
        delay(100000);
        GPIOA_ODR &= ~(1U << 5);
        delay(100000);
    }

    while(1)
    {
        /* Wait for TX register empty */
        while(!(USART2_ISR & (1U << 7)));

        /* Send letter U — easiest to identify on oscilloscope
           and has a distinctive pattern 01010101 */
        USART2_TDR = 'U';

        /* Blink LED with each send */
        GPIOA_ODR ^= (1U << 5);

        delay(1000000);
    }
}
