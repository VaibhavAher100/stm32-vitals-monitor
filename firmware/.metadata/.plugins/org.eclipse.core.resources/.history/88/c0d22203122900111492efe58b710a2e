/**
 ******************************************************************************
 * @file    main.c
 * @brief   STM32 Vitals Monitor — Monolithic prototype
 *          UART working. TMP117 and MAX30102 to be added next.
 *
 * @note    Bare-metal, no HAL. All peripherals configured via direct
 *          register writes. Addresses from RM0351 reference manual.
 *
 * Hardware:  STM32 Nucleo-L476RG
 * UART:      USART2, PA2 (TX), 9600 baud, 8N1
 *            Virtual COM port via ST-LINK — appears as COM7
 * Clock:     MSI default 4MHz after reset
 *
 * Register address reference:
 *   RCC_AHB2ENR   0x4002104C  RM0351 s6.4.17
 *   RCC_APB1ENR1  0x40021058  RM0351 s6.4.21
 *   GPIOA_MODER   0x48000000  RM0351 s8.4.1
 *   GPIOA_AFRL    0x48000020  RM0351 s8.4.9
 *   USART2_CR1    0x40004400  RM0351 s40.8.1
 *   USART2_BRR    0x4000440C  RM0351 s40.8.4  <-- offset 0x0C not 0x08
 *   USART2_ISR    0x4000441C  RM0351 s40.8.10
 *   USART2_TDR    0x40004428  RM0351 s40.8.15
 ******************************************************************************
 */

#include <stdint.h>

/* ── RCC registers ──────────────────────────────────────────────────────── */
#define RCC_AHB2ENR    (*((volatile uint32_t*)0x4002104C))
#define RCC_APB1ENR1   (*((volatile uint32_t*)0x40021058))

/* ── GPIOA registers ────────────────────────────────────────────────────── */
#define GPIOA_MODER    (*((volatile uint32_t*)0x48000000))
#define GPIOA_AFRL     (*((volatile uint32_t*)0x48000020))
#define GPIOA_ODR      (*((volatile uint32_t*)0x48000014))

/* ── USART2 registers ───────────────────────────────────────────────────── */
#define USART2_CR1     (*((volatile uint32_t*)0x40004400))
#define USART2_BRR     (*((volatile uint32_t*)0x4000440C))  /* offset 0x0C */
#define USART2_ISR     (*((volatile uint32_t*)0x4000441C))
#define USART2_TDR     (*((volatile uint32_t*)0x40004428))

/* ── Simple delay ───────────────────────────────────────────────────────── */
static void delay(volatile uint32_t count)
{
    while (count--) {}
}

/* ── UART initialisation ────────────────────────────────────────────────── */
static void uart_init(void)
{
    /* 1. Enable peripheral clocks */
    RCC_AHB2ENR  |= (1U << 0);   /* GPIOA clock enable */
    RCC_APB1ENR1 |= (1U << 17);  /* USART2 clock enable */

    /* 2. PA2 → Alternate Function mode (MODER bits 5:4 = 10) */
    GPIOA_MODER &= ~(3U << (2U * 2U));
    GPIOA_MODER |=  (2U << (2U * 2U));

    /* 3. PA2 → AF7 = USART2_TX (AFRL bits 11:8) */
    GPIOA_AFRL  &= ~(0xFU << (4U * 2U));
    GPIOA_AFRL  |=  (7U   << (4U * 2U));

    /* 4. Baud rate: 4MHz / 9600 = 416.67 → 417
       Note: BRR is at offset 0x0C. Writing to 0x08 writes CR3, not BRR. */
    USART2_BRR = 417U;

    /* 5. Enable transmitter (TE) then USART (UE) */
    USART2_CR1 |= (1U << 3);  /* TE */
    USART2_CR1 |= (1U << 0);  /* UE */
}

/* ── Send one character ─────────────────────────────────────────────────── */
static void uart_send_char(char c)
{
    /* Wait until transmit data register is empty (ISR bit 7 = TXE) */
    while ((USART2_ISR & (1U << 7)) == 0U) {}
    USART2_TDR = (uint8_t)c;
}

/* ── Send a null-terminated string ─────────────────────────────────────── */
static void uart_send_string(const char *s)
{
    while (*s != '\0')
    {
        uart_send_char(*s);
        s++;
    }
}

/* ── Print a signed 32-bit integer ─────────────────────────────────────── */
static void uart_print_int(int32_t value)
{
    char    buf[12];
    uint8_t i = 0;

    if (value < 0)
    {
        uart_send_char('-');
        value = -value;
    }

    if (value == 0)
    {
        uart_send_char('0');
        return;
    }

    while (value > 0)
    {
        buf[i++] = (char)('0' + (value % 10));
        value   /= 10;
    }

    /* Digits were stored in reverse — send them backwards */
    while (i > 0)
    {
        uart_send_char(buf[--i]);
    }
}

/* ── Main ───────────────────────────────────────────────────────────────── */
int main(void)
{
    uart_init();

    uart_send_string("========================\r\n");
    uart_send_string("STM32 Vitals Monitor\r\n");
    uart_send_string("UART OK\r\n");
    uart_send_string("========================\r\n");

    uint32_t count = 0;

    while (1)
    {
        uart_send_string("Loop count: ");
        uart_print_int((int32_t)count);
        uart_send_string("\r\n");
        count++;
        delay(500000);
    }
}
