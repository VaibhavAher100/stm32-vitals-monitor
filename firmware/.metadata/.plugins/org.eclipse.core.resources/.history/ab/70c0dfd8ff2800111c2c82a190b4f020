#include <stdint.h>

/* RCC registers */
#define RCC_AHB2ENR    (*((volatile uint32_t*)0x4002104C))
#define RCC_APB1ENR1   (*((volatile uint32_t*)0x40021058))

/* GPIOA registers */
#define GPIOA_MODER    (*((volatile uint32_t*)0x48000000))
#define GPIOA_AFRL     (*((volatile uint32_t*)0x48000020))

/* USART2 registers */
#define USART2_BRR     (*((volatile uint32_t*)0x40004408))
#define USART2_CR1     (*((volatile uint32_t*)0x40004400))
#define USART2_ISR     (*((volatile uint32_t*)0x4000441C))
#define USART2_TDR     (*((volatile uint32_t*)0x40004428))

/* Simple delay */
void delay(volatile uint32_t count)
{
    while(count--);
}

/* Send one character over USART2 */
void uart_send_char(char c)
{
    /* Wait until transmit data register is empty */
    while(!(USART2_ISR & (1U << 7)));
    USART2_TDR = c;
}

/* Send a string over USART2 */
void uart_send_string(const char* str)
{
    while(*str)
    {
        uart_send_char(*str);
        str++;
    }
}

int main(void)
{
    /* Step 1: Enable clocks for GPIOA and USART2 */
    RCC_AHB2ENR  |= (1U << 0);   /* GPIOA clock */
    RCC_APB1ENR1 |= (1U << 17);  /* USART2 clock */

    /* Step 2: Set PA2 to Alternate Function mode (bits 5:4 = 10) */
    GPIOA_MODER &= ~(3U << 4);   /* Clear bits 5:4 */
    GPIOA_MODER |=  (2U << 4);   /* Set to AF mode */

    /* Step 3: Set PA2 alternate function to AF7 (USART2_TX)
       AFRL register, bits 11:8 for PA2 */
    GPIOA_AFRL &= ~(0xFU << 8);  /* Clear bits 11:8 */
    GPIOA_AFRL |=  (7U  << 8);   /* Set AF7 */

    /* Step 4: Configure USART2
       System clock is 4MHz by default on STM32L476
       BRR = 4000000 / 9600 = 416 for 9600 baud */
    USART2_BRR = 416;

    /* Step 5: Enable USART2 - set UE bit (bit 0) and TE bit (bit 3) */
    USART2_CR1 |= (1U << 0);  /* UE: USART enable */
    USART2_CR1 |= (1U << 3);  /* TE: Transmitter enable */

    /* Send message then blink LED to confirm both work */
    /* Enable PA5 as output for LED */
    GPIOA_MODER &= ~(3U << 10);
    GPIOA_MODER |=  (1U << 10);

    while(1)
    {
        uart_send_string("Hello from STM32\r\n");
        delay(500000);
    }
}
