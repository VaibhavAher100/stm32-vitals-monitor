#include <stdint.h>

#define RCC_AHB2ENR    (*((volatile uint32_t*)0x4002104C))
#define RCC_APB1ENR1   (*((volatile uint32_t*)0x40021058))
#define GPIOA_MODER    (*((volatile uint32_t*)0x48000000))
#define GPIOA_AFRL     (*((volatile uint32_t*)0x48000020))
#define GPIOA_ODR      (*((volatile uint32_t*)0x48000014))
#define USART2_BRR     (*((volatile uint32_t*)0x40004408))
#define USART2_CR1     (*((volatile uint32_t*)0x40004400))
#define USART2_ISR     (*((volatile uint32_t*)0x4000441C))
#define USART2_TDR     (*((volatile uint32_t*)0x40004428))

void delay(volatile uint32_t count)
{
    while(count--);
}

void uart_send_char(char c)
{
    volatile uint32_t timeout = 100000;
    while(!(USART2_ISR & (1U << 7)) && timeout--);
    USART2_TDR = c;
}

void uart_send_string(const char* str)
{
    while(*str)
    {
        uart_send_char(*str++);
    }
}

int main(void)
{
    /* Enable clocks */
    RCC_AHB2ENR  |= (1U << 0);
    RCC_APB1ENR1 |= (1U << 17);

    /* PA5 as output for LED */
    GPIOA_MODER &= ~(3U << 10);
    GPIOA_MODER |=  (1U << 10);

    /* PA2 as Alternate Function for USART2_TX */
    GPIOA_MODER &= ~(3U << 4);
    GPIOA_MODER |=  (2U << 4);

    /* PA2 AF7 = USART2_TX */
    GPIOA_AFRL &= ~(0xFU << 8);
    GPIOA_AFRL |=  (7U   << 8);

    /* 9600 baud at 4MHz */
    USART2_BRR = 35;

    /* Enable USART2 and transmitter */
    USART2_CR1 |= (1U << 0);
    USART2_CR1 |= (1U << 3);

    while(1)
    {
        /* Blink LED */
        GPIOA_ODR |=  (1U << 5);
        delay(200000);
        GPIOA_ODR &= ~(1U << 5);
        delay(200000);

        /* Send UART */
        uart_send_string("Hello from STM32\r\n");
    }
