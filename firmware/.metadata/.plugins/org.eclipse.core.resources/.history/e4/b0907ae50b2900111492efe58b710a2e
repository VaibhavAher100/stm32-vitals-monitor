#include <stdint.h>

#define RCC_AHB2ENR    (*((volatile uint32_t*)0x4002104C))
#define RCC_APB1ENR1   (*((volatile uint32_t*)0x40021058))
#define RCC_APB1RSTR1  (*((volatile uint32_t*)0x40021038))
#define GPIOA_MODER    (*((volatile uint32_t*)0x48000000))
#define GPIOA_AFRL     (*((volatile uint32_t*)0x48000020))
#define GPIOA_ODR      (*((volatile uint32_t*)0x48000014))
#define USART2_BRR     (*((volatile uint32_t*)0x40004408))
#define USART2_CR1     (*((volatile uint32_t*)0x40004400))
#define USART2_ISR     (*((volatile uint32_t*)0x4000441C))
#define USART2_TDR     (*((volatile uint32_t*)0x40004428))

void delay(volatile uint32_t count)
{
    while(count--);
}

int main(void)
{
    /* Enable GPIOA clock */
    RCC_AHB2ENR |= (1U << 0);
    delay(100);

    /* PA5 as output for LED heartbeat */
    GPIOA_MODER &= ~(3U << 10);
    GPIOA_MODER |=  (1U << 10);

    /* Blink 3 times — confirms we are alive */
    for(int i = 0; i < 3; i++)
    {
        GPIOA_ODR |=  (1U << 5); delay(300000);
        GPIOA_ODR &= ~(1U << 5); delay(300000);
    }

    /* Enable USART2 clock */
    RCC_APB1ENR1 |= (1U << 17);
    delay(100);

    /* Reset USART2 peripheral completely */
    RCC_APB1RSTR1 |=  (1U << 17);
    delay(100);
    RCC_APB1RSTR1 &= ~(1U << 17);
    delay(100);

    /* PA2 to Alternate Function mode */
    GPIOA_MODER &= ~(3U << 4);
    GPIOA_MODER |=  (2U << 4);
    delay(10);

    /* PA2 AF7 = USART2_TX */
    GPIOA_AFRL &= ~(0xFU << 8);
    GPIOA_AFRL |=  (7U   << 8);
    delay(10);

    /* Make sure USART2 is disabled before configuring */
    USART2_CR1 = 0;
    delay(10);

    /* BRR = 4MHz / 9600 = 417 */
    USART2_BRR = 417;
    delay(10);

    /* Enable USART2 (UE) and Transmitter (TE) */
    USART2_CR1 |= (1U << 0);
    delay(10);
    USART2_CR1 |= (1U << 3);
    delay(100);

    /* Blink once — confirms UART init complete */
    GPIOA_ODR |=  (1U << 5); delay(500000);
    GPIOA_ODR &= ~(1U << 5); delay(500000);

    while(1)
    {
        /* Wait for TX empty */
        while(!(USART2_ISR & (1U << 7)));

        /* Send U = 0x55 = 01010101 */
        USART2_TDR = 'U';

        /* Toggle LED with each byte */
        GPIOA_ODR ^= (1U << 5);

        delay(500000);
    }
}
